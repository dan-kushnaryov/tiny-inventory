# Copy to `server/.env` — required by Nest (`ConfigModule` + Joi); no in-app defaults.
# Compose interpolation values live in repo-root `.env` (recommended).

# --- Nest (local `npm run start:dev` or values passed into the `app` container) ---
PORT=3000

DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tiny_inventory
DB_SYNC=true

# --- Optional: Compose published ports (if you choose to pass this file to compose) ---
# KNOSTIC_DEV_DB_PORT=5433
# KNOSTIC_DEV_APP_PORT=3000
# KNOSTIC_TEST_DB_PUBLISH=5544

# Local Nest with Postgres from Compose (`docker compose up -d` from repo root or `server/`):
#   DB_HOST=localhost, DB_PORT = published dev Postgres (default 5433).
# Nest in Docker (`npm run start:dev:docker`): Compose overrides DB_HOST=postgres, DB_PORT=5432.
