# Copy to `server/.env.test` for e2e on the host (`npm run test:e2e`).
# Vitest loads this file via `test/setup.ts` (see Vite `loadEnv('test', …)`).
#
# Use a database separate from dev. Create once, e.g. (default dev Postgres on host port 5433):
#   psql "postgresql://postgres:postgres@localhost:5433/postgres" -c "CREATE DATABASE tiny_inventory_test;"
#
# If you changed KNOSTIC_DEV_DB_PORT in `server/.env`, use that port here for DB_PORT.
#
# Docker e2e (`npm run test:e2e:docker`) ignores this file and injects env from Compose (profile `test`).

PORT=3001
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tiny_inventory_test
DB_SYNC=true
