# Optional Compose overrides (repo root). Copy to `.env` if you need non-default ports.
# Defaults allow running full stack + optional test profile without host port clashes.

# Published host port for dev Postgres (maps to container 5432).
KNOSTIC_DEV_DB_PORT=5433

# Published host port for the Nest dev app.
KNOSTIC_DEV_APP_PORT=3000

# Published host port for the web container.
KNOSTIC_WEB_PORT=5173

# API base URL baked into web build (used by `web/docker-compose.yml`).
# For host browser + Dockerized server, `localhost:<app-port>` is correct.
VITE_API_URL=http://localhost:3000

# Published host port for e2e Postgres (optional; for psql from host against test DB).
KNOSTIC_TEST_DB_PUBLISH=5544
