# Copy to `web/.env` — all variables are required (no defaults in code).

# Dev server port (`npm run dev`).
VITE_DEV_PORT=5173

# Proxy target for `/stores`, `/products`, `/categories` — must match Nest `PORT` in `server/.env`.
VITE_PROXY_API=http://localhost:3000

# Base URL for API requests from the browser.
# - http://localhost:3000 — direct to Nest (requests show as :3000 in DevTools; CORS must allow the Vite origin).
# - Empty (VITE_API_URL=) — relative URLs to the Vite origin (:5173); dev server proxies to VITE_PROXY_API (Network still shows :5173).
VITE_API_URL=http://localhost:3000
